{
  "name": "lbt",
  "displayName": "Lancelot Build Tool (LBT)",
  "description": "Automated build tool for IBM i",
  "publisher": "roland-strauss",
  "version": "0.7.00",
  "icon": "asserts/img/ext/logo.png",
  "keywords": [
    "ibm i",
    "ibmi",
    "iseries",
    "as400",
    "rpgle",
    "ile",
    "build"
  ],
  "author": {
    "name": "Roland Strauss"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/RolandStrauss/lbt-extension"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lbt.show_changes",
        "title": "%lbt.show_changes%",
        "icon": "$(check-all)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.show_single_changes",
        "title": "%lbt.show_single_changes%",
        "icon": "$(check)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.run_build",
        "title": "%lbt.run_build%",
        "icon": "$(run-all)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.run_single_build",
        "title": "%lbt.run_single_build%",
        "icon": "$(run)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.update",
        "title": "%lbt.source-filter.update%",
        "icon": "$(refresh)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.add",
        "title": "%lbt.source-filter.add%",
        "icon": "$(add)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.get-remote-compiled-object-list",
        "title": "%lbt.get-remote-compiled-object-list%",
        "icon": "$(arrow-circle-down)",
        "when": "lbt.contains_lbt_project && lbt.valid-config && false"
      },
      {
        "command": "lbt.copy-profile-config",
        "title": "%lbt.copy-profile-config%",
        "icon": "$(person-add)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.reset-compiled-object-list",
        "title": "%lbt.reset-compiled-object-list%",
        "icon": "$(extensions)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.get-remote-source-list",
        "title": "%lbt.get-remote-source-list%",
        "icon": "$(arrow-down)",
        "when": "lbt.contains_lbt_project && lbt.valid-config && false"
      },
      {
        "command": "lbt.check-remote-sources",
        "title": "%lbt.check-remote-sources%",
        "icon": "$(tasklist)",
        "when": "lbt.contains_lbt_project && lbt.valid-config && false"
      },
      {
        "command": "lbt.controller.config",
        "title": "%lbt.controller.config%",
        "icon": "$(settings-gear)",
        "when": "lbt.contains_lbt_project"
      },
      {
        "command": "lbt.controller.dependency-list",
        "title": "%lbt.controller.dependency-list%",
        "icon": "$(outline-view-icon)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source.edit-compile-config",
        "title": "%lbt.source.edit-compile-config%",
        "icon": "$(settings-gear)",
        "when": "lbt.contains_lbt_project"
      },
      {
        "command": "lbt.transfer-all",
        "title": "%lbt.transfer-all%",
        "icon": "$(cloud-upload)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.show-view",
        "title": "%lbt.source-filter.show-view%",
        "icon": "$(preview)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.edit-config",
        "title": "%lbt.source-filter.edit-config%",
        "icon": "$(settings-gear)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.delete-config",
        "title": "%lbt.source-filter.delete-config%",
        "icon": "$(trash)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.view-source-infos",
        "title": "%lbt.source-filter.view-source-infos%",
        "icon": "$(preview)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.maintain-source-infos",
        "title": "%lbt.source-filter.maintain-source-infos%",
        "icon": "$(settings-gear)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.add-source-file",
        "title": "%lbt.source-filter.add-source-file%",
        "icon": "$(add)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.add-source-member",
        "title": "%lbt.source-filter.add-source-member%",
        "icon": "$(add)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.change-source-description",
        "title": "%lbt.source-filter.change-source-description%",
        "icon": "$(preview)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.rename-source-member",
        "title": "%lbt.source-filter.rename-source-member%",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source-filter.delete-source-member",
        "title": "%lbt.source-filter.delete-source-member%",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.source.maintain-source-dependency",
        "title": "%lbt.source.maintain-source-dependency%",
        "icon": "$(combine)",
        "when": "lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.deployment.maintain",
        "title": "%lbt.deployment.maintain%",
        "icon": "$(settings-gear)",
        "when": "1==2 && lbt.contains_lbt_project && lbt.valid-config"
      },
      {
        "command": "lbt.build-history.update",
        "title": "Update Build History"
      },
      {
        "command": "lbt.build-history.delete-item",
        "title": "Delete Build History Item",
        "icon": "$(trash)"
      },
      {
        "command": "lbt.build-history.delete-date",
        "title": "Delete Build History for Date",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "lbt.source-filter.add",
          "when": "lbt.contains_lbt_project && lbt.valid-config && view == lbt.source-filter",
          "group": "navigation@1"
        },
        {
          "command": "lbt.source-filter.view-source-infos",
          "when": "lbt.contains_lbt_project && lbt.valid-config && view == lbt.source-filter",
          "group": "navigation@2"
        },
        {
          "command": "lbt.source-filter.maintain-source-infos",
          "when": "lbt.contains_lbt_project && lbt.valid-config && view == lbt.source-filter",
          "group": "navigation@3"
        },
        {
          "command": "lbt.source-filter.update",
          "when": "lbt.contains_lbt_project && lbt.valid-config && view == lbt.source-filter",
          "group": "navigation@5"
        },
        {
          "command": "lbt.get-remote-source-list",
          "when": "false && lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@20"
        },
        {
          "command": "lbt.get-remote-compiled-object-list",
          "when": "false && lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@30"
        },
        {
          "command": "lbt.reset-compiled-object-list",
          "when": "lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@40"
        },
        {
          "command": "lbt.check-remote-sources",
          "when": "false && lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@50"
        },
        {
          "command": "lbt.transfer-all",
          "when": "lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@60"
        },
        {
          "command": "lbt.controller.dependency-list",
          "when": "lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@65"
        },
        {
          "command": "lbt.controller.config",
          "when": "lbt.contains_lbt_project && (view == lbt.controller || (!lbt.valid-config && view == ldm-config-invalid))",
          "group": "navigation@70"
        },
        {
          "command": "lbt.deployment.maintain",
          "when": "lbt.contains_lbt_project && lbt.valid-config && view == lbt.deployment",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "lbt.source.edit-compile-config",
          "when": "lbt.contains_lbt_project"
        },
        {
          "command": "lbt.source-filter.change-source-description",
          "when": "lbt.contains_lbt_project"
        },
        {
          "command": "lbt.source.maintain-source-dependency",
          "when": "lbt.contains_lbt_project"
        }
      ],
      "explorer/context": [
        {
          "command": "lbt.source.edit-compile-config",
          "when": "lbt.contains_lbt_project"
        },
        {
          "command": "lbt.source-filter.change-source-description",
          "when": "lbt.contains_lbt_project"
        },
        {
          "command": "lbt.source.maintain-source-dependency",
          "when": "lbt.contains_lbt_project"
        }
      ],
      "view/item/context": [
        {
          "command": "lbt.source-filter.show-view",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == source-list",
          "group": "inline@0"
        },
        {
          "command": "lbt.source-filter.edit-config",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == source-list",
          "group": "inline@2"
        },
        {
          "command": "lbt.source-filter.delete-config",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == source-list",
          "group": "inline@3"
        },
        {
          "command": "lbt.source.edit-compile-config",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == lbt-source",
          "group": "inline@0"
        },
        {
          "command": "lbt.source.maintain-source-dependency",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == lbt-source",
          "group": "inline@1"
        },
        {
          "command": "lbt.source-filter.change-source-description",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == lbt-source",
          "group": "inline@1"
        },
        {
          "command": "lbt.source-filter.rename-source-member",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == lbt-source"
        },
        {
          "command": "lbt.source-filter.delete-source-member",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == lbt-source"
        },
        {
          "command": "lbt.source-filter.add-source-member",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == source-file",
          "group": "inline@0"
        },
        {
          "command": "lbt.source-filter.add-source-file",
          "when": "lbt.contains_lbt_project && view == lbt.source-filter && viewItem == source-lib",
          "group": "inline@0"
        },
        {
          "command": "lbt.build-history.delete-item",
          "when": "view == lbt.build-history && viewItem == buildHistoryFile",
          "group": "inline"
        },
        {
          "command": "lbt.build-history.delete-date",
          "when": "view == lbt.build-history && viewItem == buildHistoryDate",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lbt-bar",
          "title": "Lancelot Build Tool",
          "icon": "$(code)"
        }
      ]
    },
    "views": {
      "lbt-bar": [
        {
          "type": "webview",
          "id": "lbt.controller",
          "name": "lbt Build",
          "when": "lbt.contains_lbt_project && lbt.valid-config"
        },
        {
          "type": "tree",
          "id": "lbt.build-history",
          "name": "Build history",
          "when": "lbt.contains_lbt_project && lbt.valid-config"
        },
        {
          "type": "tree",
          "id": "lbt.source-filter",
          "name": "%Source filters%",
          "when": "lbt.contains_lbt_project && lbt.valid-config"
        },
        {
          "type": "webview",
          "id": "lbt.quick-settings",
          "name": "%Quick settings%",
          "when": "false && lbt.contains_lbt_project && lbt.valid-config"
        },
        {
          "type": "webview",
          "id": "lbt.deployment",
          "name": "%deployment%",
          "when": "1==2 && lbt.contains_lbt_project && lbt.valid-config"
        },
        {
          "type": "webview",
          "id": "lbt-welcome",
          "name": "%Welcome%",
          "when": "lbt.contains_lbt_project == false"
        },
        {
          "type": "webview",
          "id": "lbt-config-invalid",
          "name": "%Invalid config%",
          "when": "lbt.contains_lbt_project && !lbt.valid-config"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package --omit=dev",
    "compile": "node ./esbuild.js",
    "package": "NODE_ENV=production node ./esbuild.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "postinstall": "if exist node_modules\\ssh2\\test rd /s /q node_modules\\ssh2\\test"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.33",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.100.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "latest",
    "ovsx": "latest"
  },
  "dependencies": {
    "@emnapi/core": "^1.4.3",
    "@emnapi/runtime": "^1.4.3",
    "@tybys/wasm-util": "^0.9.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "deepmerge": "^4.3.1",
    "esbuild": "^0.25.10",
    "fs-extra": "^11.2.0",
    "hasha": "^6.0.0",
    "node-ssh": "^13.2.0",
    "nunjucks": "^3.2.4",
    "smol-toml": "^1.3.0",
    "wildcard-match": "latest",
    "winston": "latest",
    "winston-transport": "latest"
  }
}
