{
  "name": "ldm",
  "displayName": "Lancelot Development Manager (LDM)",
  "description": "Automated build tool for IBM i",
  "publisher": "roland-strauss",
  "version": "0.6.12",
  "icon": "asserts/img/ext/logo.png",
  "keywords": [
    "ibm i",
    "ibmi",
    "iseries",
    "as400",
    "rpgle",
    "ile",
    "build"
  ],
  "author": {
    "name": "Roland Strauss",
    "url": "https://www.prouza.at"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/RolandStrauss/lbt-extension"
  },
  "engines": {
    "vscode": "^1.66.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ldm.show_changes",
        "title": "%ldm.show_changes%",
        "icon": "$(check-all)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.show_single_changes",
        "title": "%ldm.show_single_changes%",
        "icon": "$(check)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.run_build",
        "title": "%ldm.run_build%",
        "icon": "$(run-all)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.run_single_build",
        "title": "%ldm.run_single_build%",
        "icon": "$(run)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.update",
        "title": "%ldm.source-filter.update%",
        "icon": "$(refresh)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.add",
        "title": "%ldm.source-filter.add%",
        "icon": "$(add)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.get-remote-compiled-object-list",
        "title": "%ldm.get-remote-compiled-object-list%",
        "icon": "$(arrow-circle-down)",
        "when": "ldm.contains_ldm_project && ldm.valid-config && false"
      },
      {
        "command": "ldm.copy-profile-config",
        "title": "%ldm.copy-profile-config%",
        "icon": "$(person-add)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.reset-compiled-object-list",
        "title": "%ldm.reset-compiled-object-list%",
        "icon": "$(extensions)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.get-remote-source-list",
        "title": "%ldm.get-remote-source-list%",
        "icon": "$(arrow-down)",
        "when": "ldm.contains_ldm_project && ldm.valid-config && false"
      },
      {
        "command": "ldm.check-remote-sources",
        "title": "%ldm.check-remote-sources%",
        "icon": "$(tasklist)",
        "when": "ldm.contains_ldm_project && ldm.valid-config && false"
      },
      {
        "command": "ldm.controller.config",
        "title": "%ldm.controller.config%",
        "icon": "$(settings-gear)",
        "when": "ldm.contains_ldm_project"
      },
      {
        "command": "ldm.controller.dependency-list",
        "title": "%ldm.controller.dependency-list%",
        "icon": "$(outline-view-icon)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source.edit-compile-config",
        "title": "%ldm.source.edit-compile-config%",
        "icon": "$(settings-gear)",
        "when": "ldm.contains_ldm_project"
      },
      {
        "command": "ldm.transfer-all",
        "title": "%ldm.transfer-all%",
        "icon": "$(cloud-upload)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.show-view",
        "title": "%ldm.source-filter.show-view%",
        "icon": "$(preview)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.edit-config",
        "title": "%ldm.source-filter.edit-config%",
        "icon": "$(settings-gear)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.delete-config",
        "title": "%ldm.source-filter.delete-config%",
        "icon": "$(trash)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.view-source-infos",
        "title": "%ldm.source-filter.view-source-infos%",
        "icon": "$(preview)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.maintain-source-infos",
        "title": "%ldm.source-filter.maintain-source-infos%",
        "icon": "$(settings-gear)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.add-source-file",
        "title": "%ldm.source-filter.add-source-file%",
        "icon": "$(add)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.add-source-member",
        "title": "%ldm.source-filter.add-source-member%",
        "icon": "$(add)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.change-source-description",
        "title": "%ldm.source-filter.change-source-description%",
        "icon": "$(preview)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.rename-source-member",
        "title": "%ldm.source-filter.rename-source-member%",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source-filter.delete-source-member",
        "title": "%ldm.source-filter.delete-source-member%",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.source.maintain-source-dependency",
        "title": "%ldm.source.maintain-source-dependency%",
        "icon": "$(combine)",
        "when": "ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.deployment.maintain",
        "title": "%ldm.deployment.maintain%",
        "icon": "$(settings-gear)",
        "when": "1==2 && ldm.contains_ldm_project && ldm.valid-config"
      },
      {
        "command": "ldm.build-history.update",
        "title": "Update Build History"
      },
      {
        "command": "ldm.build-history.delete-item",
        "title": "Delete Build History Item",
        "icon": "$(trash)"
      },
      {
        "command": "ldm.build-history.delete-date",
        "title": "Delete Build History for Date",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ldm.source-filter.add",
          "when": "ldm.contains_ldm_project && ldm.valid-config && view == ldm.source-filter",
          "group": "navigation@1"
        },
        {
          "command": "ldm.source-filter.view-source-infos",
          "when": "ldm.contains_ldm_project && ldm.valid-config && view == ldm.source-filter",
          "group": "navigation@2"
        },
        {
          "command": "ldm.source-filter.maintain-source-infos",
          "when": "ldm.contains_ldm_project && ldm.valid-config && view == ldm.source-filter",
          "group": "navigation@3"
        },
        {
          "command": "ldm.source-filter.update",
          "when": "ldm.contains_ldm_project && ldm.valid-config && view == ldm.source-filter",
          "group": "navigation@5"
        },
        {
          "command": "ldm.get-remote-source-list",
          "when": "false && ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@20"
        },
        {
          "command": "ldm.get-remote-compiled-object-list",
          "when": "false && ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@30"
        },
        {
          "command": "ldm.reset-compiled-object-list",
          "when": "ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@40"
        },
        {
          "command": "ldm.check-remote-sources",
          "when": "false && ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@50"
        },
        {
          "command": "ldm.transfer-all",
          "when": "ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@60"
        },
        {
          "command": "ldm.controller.dependency-list",
          "when": "ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@65"
        },
        {
          "command": "ldm.controller.config",
          "when": "ldm.contains_ldm_project && (view == ldm.controller || (!ldm.valid-config && view == ldm-config-invalid))",
          "group": "navigation@70"
        },
        {
          "command": "ldm.deployment.maintain",
          "when": "ldm.contains_ldm_project && ldm.valid-config && view == ldm.deployment",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "ldm.source.edit-compile-config",
          "when": "ldm.contains_ldm_project"
        },
        {
          "command": "ldm.source-filter.change-source-description",
          "when": "ldm.contains_ldm_project"
        },
        {
          "command": "ldm.source.maintain-source-dependency",
          "when": "ldm.contains_ldm_project"
        }
      ],
      "explorer/context": [
        {
          "command": "ldm.source.edit-compile-config",
          "when": "ldm.contains_ldm_project"
        },
        {
          "command": "ldm.source-filter.change-source-description",
          "when": "ldm.contains_ldm_project"
        },
        {
          "command": "ldm.source.maintain-source-dependency",
          "when": "ldm.contains_ldm_project"
        }
      ],
      "view/item/context": [
        {
          "command": "ldm.source-filter.show-view",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == source-list",
          "group": "inline@0"
        },
        {
          "command": "ldm.source-filter.edit-config",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == source-list",
          "group": "inline@2"
        },
        {
          "command": "ldm.source-filter.delete-config",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == source-list",
          "group": "inline@3"
        },
        {
          "command": "ldm.source.edit-compile-config",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == ldm-source",
          "group": "inline@0"
        },
        {
          "command": "ldm.source.maintain-source-dependency",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == ldm-source",
          "group": "inline@1"
        },
        {
          "command": "ldm.source-filter.change-source-description",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == ldm-source",
          "group": "inline@1"
        },
        {
          "command": "ldm.source-filter.rename-source-member",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == ldm-source"
        },
        {
          "command": "ldm.source-filter.delete-source-member",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == ldm-source"
        },
        {
          "command": "ldm.source-filter.add-source-member",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == source-file",
          "group": "inline@0"
        },
        {
          "command": "ldm.source-filter.add-source-file",
          "when": "ldm.contains_ldm_project && view == ldm.source-filter && viewItem == source-lib",
          "group": "inline@0"
        },
        {
          "command": "ldm.build-history.delete-item",
          "when": "view == ldm.build-history && viewItem == buildHistoryFile",
          "group": "inline"
        },
        {
          "command": "ldm.build-history.delete-date",
          "when": "view == ldm.build-history && viewItem == buildHistoryDate",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ldm-bar",
          "title": "Lancelot Development Manager",
          "icon": "$(code)"
        }
      ]
    },
    "views": {
      "ldm-bar": [
        {
          "type": "webview",
          "id": "ldm.controller",
          "name": "ldm Build",
          "when": "ldm.contains_ldm_project && ldm.valid-config"
        },
        {
          "type": "tree",
          "id": "ldm.build-history",
          "name": "Build history",
          "when": "ldm.contains_ldm_project && ldm.valid-config"
        },
        {
          "type": "tree",
          "id": "ldm.source-filter",
          "name": "%Source filters%",
          "when": "ldm.contains_ldm_project && ldm.valid-config"
        },
        {
          "type": "webview",
          "id": "ldm.quick-settings",
          "name": "%Quick settings%",
          "when": "false && ldm.contains_ldm_project && ldm.valid-config"
        },
        {
          "type": "webview",
          "id": "ldm.deployment",
          "name": "%deployment%",
          "when": "1==2 && ldm.contains_ldm_project && ldm.valid-config"
        },
        {
          "type": "webview",
          "id": "ldm-welcome",
          "name": "%Welcome%",
          "when": "ldm.contains_ldm_project == false"
        },
        {
          "type": "webview",
          "id": "ldm-config-invalid",
          "name": "%Invalid config%",
          "when": "ldm.contains_ldm_project && !ldm.valid-config"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package --omit=dev",
    "compile": "node ./esbuild.js",
    "package": "NODE_ENV=production node ./esbuild.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "postinstall": "rm -rf node_modules/ssh2/test"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.66.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "eslint": "latest",
    "ovsx": "latest"
  },
  "dependencies": {
    "@emnapi/core": "^1.4.3",
    "@emnapi/runtime": "^1.4.3",
    "@tybys/wasm-util": "^0.9.0",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "deepmerge": "^4.3.1",
    "fs-extra": "^11.2.0",
    "hasha": "^6.0.0",
    "node-ssh": "^13.2.0",
    "nunjucks": "^3.2.4",
    "smol-toml": "^1.3.0",
    "wildcard-match": "latest",
    "winston": "latest",
    "winston-transport": "latest",
    "esbuild": "^0.25.10"
  }
}
